{
  "name": "agentsession-workspace",
  "version": "1.7.0",
  "description": "AgentSession — a local-first multi-provider viewer and manager for AI coding sessions.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "npm run build:core && npm run build --workspace=@acetamido/agentsession-mcp",
    "build:binary": "node scripts/build-sea.mjs",
    "smoke:binary": "node scripts/smoke-sea.mjs",
    "build:core": "node scripts/clean-dist.mjs && tsc && node scripts/copy-static.mjs && node scripts/copy-package-dist.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "start": "npm run build && node dist/bin/cli.js",
    "dev": "npm run build && node dist/bin/cli.js --open",
    "typecheck": "tsc --noEmit",
    "qa:e2e": "scripts\\qa-agent-browser.cmd",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "agentsession",
    "agent-session",
    "opencode",
    "claude-code",
    "codex",
    "gemini",
    "pi-coding-agent",
    "session-viewer",
    "ai-coding",
    "session-manager",
    "cli"
  ],
  "author": "Guanzhw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Guanzhw/AgentSession.git"
  },
  "homepage": "https://github.com/Guanzhw/AgentSession",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "^24.10.1",
    "esbuild": "0.28.1",
    "typescript": "^5.9.3"
  }
}
